# VITE_SUPABASE_URL: Your Supabase project URL (Project Settings > API > Project URL).
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase publishable/anon API key (Project Settings > API).
# Safe to expose in the browser — access is enforced by Row Level Security policies.
VITE_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
